PORT=3001

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT Auth
JWT_SECRET=your_long_random_jwt_secret
JWT_EXPIRES_IN=8h

# Initial Admin User
# Used only when running: npm run create-admin
ADMIN_FULL_NAME=Perraro Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password

# Admin Password Reset
# Used only when running: npm run reset-admin-password
RESET_ADMIN_EMAIL=admin@example.com
RESET_ADMIN_PASSWORD=change_this_password

# OpenPhone SMS
OPENPHONE_API_KEY=your_openphone_api_key
OPENPHONE_PHONE_NUMBER_ID=your_openphone_phone_number_id

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_app_password
SMTP_FROM_NAME=Perraro Electric Bike
SMTP_FROM_EMAIL=your_email@example.com

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://tickets.example.com,https://www.example-store.com