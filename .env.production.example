PORT=3001
NODE_ENV=production
TEMP_DIR=/var/tmp/ticketing-system

# Frontend origin allowed by backend CORS.
CORS_ORIGINS=https://tickets.example.com

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

# JWT Auth
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=8h

# Initial Admin User
# Used only when running: docker compose run --rm ticketing-backend npm run create-admin
ADMIN_FULL_NAME=Support Desk Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password

# Admin Password Reset
# Used only when running: docker compose run --rm ticketing-backend npm run reset-admin-password
RESET_ADMIN_EMAIL=admin@example.com
RESET_ADMIN_PASSWORD=replace_with_strong_password

# OpenPhone SMS / API
OPENPHONE_API_KEY=replace_with_openphone_api_key
OPENPHONE_PHONE_NUMBER_ID=replace_with_openphone_phone_number_id

# SMTP Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=replace_with_smtp_password
SMTP_FROM_NAME=Demo Support Desk
SMTP_FROM_EMAIL=mailer@example.com

# Intake Webhook Secret for n8n -> backend notify calls.
INTAKE_SECRET=replace_with_long_random_secret

# Optional company SMS alert for website_form ticket-created notifications.
COMPANY_ALERT_PHONE_NUMBER=+15555555555

# External attachment storage. Backend stores outbound/OpenPhone files in Supabase Storage.
# Existing n8n workflows may store intake files in Google Drive and save Drive URLs in Supabase.
SUPABASE_ATTACHMENTS_BUCKET=attachments
