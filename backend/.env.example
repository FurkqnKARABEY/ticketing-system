PORT=3001

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT Auth
JWT_SECRET=your_long_random_jwt_secret
JWT_EXPIRES_IN=8h

# Initial Admin User
# Used only when running: npm run create-admin
ADMIN_FULL_NAME=Perraro Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password

# Admin Password Reset
# Used only when running: npm run reset-admin-password
RESET_ADMIN_EMAIL=admin@example.com
RESET_ADMIN_PASSWORD=change_this_password

# OpenPhone SMS
OPENPHONE_API_KEY=your_openphone_api_key
OPENPHONE_PHONE_NUMBER_ID=your_openphone_phone_number_id

# Company alert SMS (website_form tickets only)
COMPANY_ALERT_PHONE_NUMBER=+16503924896

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_app_password
SMTP_FROM_NAME=Support Desk
SMTP_FROM_EMAIL=your_email@example.com

# Intake Webhook Secret (for n8n -> backend notify calls)
INTAKE_SECRET=change_this_secret

# Supabase Storage (optional but recommended)
SUPABASE_ATTACHMENTS_BUCKET=attachments
