<!-- Support Desk - Customer Support Ticket Form -->
<!--
  Notes:
  - This is a template snippet intended to be adapted to your storefront.
  - Update the form action / webhook endpoint as needed.
-->

<section class="support-ticket-shell" aria-labelledby="support-ticket-title">
  <div class="support-ticket-wrap">
    <div class="support-ticket-card">
      <div class="support-ticket-brand">
        <div class="support-ticket-wordmark">
          <span class="support-ticket-wordmark-strong">Support Desk</span>
        </div>
      </div>

      <div class="support-ticket-header">
        <p class="support-ticket-kicker">Customer Support</p>
        <h1 id="support-ticket-title">
          <span class="support-title-strong">Support Desk</span>
          <span class="support-title-soft"> Support Request</span>
        </h1>
        <p class="support-ticket-intro">
          Submit your request and our team will follow up as soon as possible.
        </p>
      </div>

      <form id="support-ticket-form" class="support-ticket-form" enctype="multipart/form-data" novalidate>
        <div class="support-grid two">
          <div class="support-field">
            <label for="support-first-name">First Name <span aria-hidden="true">*</span></label>
            <input id="support-first-name" name="first_name" type="text" autocomplete="given-name" required>
          </div>

          <div class="support-field">
            <label for="support-last-name">Last Name <span aria-hidden="true">*</span></label>
            <input id="support-last-name" name="last_name" type="text" autocomplete="family-name" required>
          </div>
        </div>

        <div class="support-grid two">
          <div class="support-field">
            <label for="support-email">Email <span aria-hidden="true">*</span></label>
            <input id="support-email" name="email" type="email" autocomplete="email" required>
          </div>

          <div class="support-field">
            <label for="support-phone">Phone</label>
            <input id="support-phone" name="phone" type="tel" autocomplete="tel">
          </div>
        </div>

        <div class="support-grid two">
          <div class="support-field">
            <label for="support-order-number">Order Number</label>
            <input id="support-order-number" name="order_number" type="text" autocomplete="off">
          </div>

          <div class="support-field">
            <label for="support-product-model">Product Model</label>
            <input id="support-product-model" name="product_model" type="text" autocomplete="off">
          </div>
        </div>

        <div class="support-field">
          <label for="support-subject">Subject <span aria-hidden="true">*</span></label>
          <input id="support-subject" name="subject" type="text" required>
        </div>

        <div class="support-field">
          <label for="support-message">Message <span aria-hidden="true">*</span></label>
          <textarea id="support-message" name="message" rows="5" required></textarea>
        </div>

        <div class="support-field">
          <label for="support-attachments">Attachments</label>
          <input id="support-attachments" name="attachments" type="file" multiple>
          <div id="support-file-list" class="support-file-list" aria-live="polite"></div>
        </div>

        <button id="support-submit-button" type="submit" class="support-submit">
          <span class="support-button-label">Submit</span>
          <span class="support-button-loading" style="display:none;">Submitting...</span>
        </button>

        <div id="support-form-status" class="support-status" role="status" aria-live="polite"></div>
      </form>
    </div>
  </div>
</section>

<style>
  .support-ticket-shell { padding: 24px; }
  .support-ticket-wrap { display: grid; place-items: center; }
  .support-ticket-card { width: min(100%, 720px); background: #fff; border: 1px solid #e2e8f0; border-radius: 18px; padding: 22px; }
  .support-ticket-kicker { margin: 0; color: #64748b; font-weight: 700; }
  .support-ticket-intro { margin: 10px 0 0; color: #475569; }
  .support-grid.two { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .support-field { display: grid; gap: 6px; margin-top: 12px; }
  .support-field label { font-weight: 800; font-size: 13px; color: #334155; }
  .support-field input, .support-field textarea { border: 1px solid #cbd5e1; border-radius: 12px; padding: 12px; font: inherit; }
  .support-submit { margin-top: 16px; border: 0; border-radius: 12px; padding: 12px 14px; font-weight: 900; background: #0f172a; color: #fff; width: 100%; }
  .support-file-list { display: grid; gap: 8px; margin-top: 8px; }
  .support-status { margin-top: 12px; font-weight: 800; }
  @media (max-width: 640px) { .support-grid.two { grid-template-columns: 1fr; } }
</style>

<script>
  (function () {
    var form = document.getElementById('support-ticket-form');
    var fileInput = document.getElementById('support-attachments');
    var fileList = document.getElementById('support-file-list');
    var statusBox = document.getElementById('support-form-status');
    var submitButton = document.getElementById('support-submit-button');
    var submitLabel = submitButton.querySelector('.support-button-label');
    var submitLoading = submitButton.querySelector('.support-button-loading');

    function setStatus(message, type) {
      statusBox.textContent = message || '';
      statusBox.className = 'support-status ' + (type || '');
    }

    function renderFiles() {
      fileList.innerHTML = '';
      var files = fileInput.files ? Array.prototype.slice.call(fileInput.files) : [];
      files.forEach(function (file) {
        var row = document.createElement('div');
        row.textContent = file.name + ' (' + Math.ceil(file.size / 1024) + ' KB)';
        fileList.appendChild(row);
      });
    }

    fileInput.addEventListener('change', renderFiles);

    form.addEventListener('submit', function (event) {
      event.preventDefault();
      setStatus('');

      submitButton.disabled = true;
      submitLabel.style.display = 'none';
      submitLoading.style.display = 'inline';

      // TODO: Replace with your backend endpoint
      // fetch('/your-webhook-endpoint', { method: 'POST', body: new FormData(form) })
      //   .then(...)
      window.setTimeout(function () {
        submitButton.disabled = false;
        submitLoading.style.display = 'none';
        submitLabel.style.display = 'inline';
        setStatus('Submitted (template stub).', 'success');
      }, 500);
    });
  })();
</script>
