    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfunction clean(value) {\n  return String(value || '').trim();\n}\n\nfunction normalizePhone(value) {\n  const digits = String(value || '').replace(/\\D/g, '');\n  if (!digits) return '';\n  if (digits.length === 11 && digits.startsWith('1')) return digits.slice(1);\n  return digits.slice(-10);\n}\n\nreturn items.map(item => {\n  const body = item.json.body || {};\n  const object = body.data?.object || body.data || body;\n\n  const direction = clean(object.direction);\n\n  const rawFrom = clean(object.from);\n  const rawTo = clean(object.to);\n\n  const customerPhone =\n    direction === 'outgoing'\n      ? rawTo\n      : rawFrom;\n\n  const authorType =\n    direction === 'outgoing'\n      ? 'technician'\n      : 'customer';\n\n  const phoneNormalized = normalizePhone(customerPhone);\n\n  const messageId = clean(object.id || object.messageId);\n\n  const messageBody = clean(\n    object.text ||\n    object.body ||\n    object.content ||\n    object.message ||\n    ''\n  );\n\n  return {\n    json: {\n      channel: 'openphone_sms',\n      direction,\n      author_type: authorType,\n\n      phone_number: customerPhone,\n      phone_number_normalized: phoneNormalized,\n\n      message_type: 'sms',\n      message_body: messageBody,\n\n      openphone_message_id: messageId || null,\n      external_id: messageId || null,\n\n      occurred_at: clean(object.createdAt || object.created_at) || new Date().toISOString(),\n\n      raw_payload: body\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
