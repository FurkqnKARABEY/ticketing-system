    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfunction clean(value) {\n  return String(value || '').trim();\n}\n\nfunction getAttachments(payload) {\n  const object = payload?.data?.object || payload?.data || payload || {};\n\n  const possible =\n    object.attachments ||\n    object.media ||\n    object.files ||\n    object.images ||\n    object.data?.attachments ||\n    [];\n\n  if (Array.isArray(possible)) return possible;\n\n  if (possible && typeof possible === 'object') return [possible];\n\n  return [];\n}\n\nconst output = [];\n\nfor (const item of items) {\n  const communication = item.json;\n\n  const normalized = $('Normalize OpenPhone Message').item.json;\n  const rawPayload = normalized.raw_payload || {};\n\n  const attachments = getAttachments(rawPayload);\n\n  for (const att of attachments) {\n    const fileUrl =\n      att.url ||\n      att.fileUrl ||\n      att.downloadUrl ||\n      att.mediaUrl ||\n      att.contentUrl ||\n      att.src ||\n      null;\n\n    const fileName =\n      att.name ||\n      att.fileName ||\n      att.filename ||\n      att.title ||\n      null;\n\n    const mimeType =\n      att.mimeType ||\n      att.contentType ||\n      att.type ||\n      null;\n\n    const sizeBytes =\n      att.size ||\n      att.sizeBytes ||\n      att.bytes ||\n      null;\n\n    const externalId =\n      att.id ||\n      att.mediaId ||\n      att.fileId ||\n      normalized.openphone_message_id ||\n      null;\n\n    output.push({\n      json: {\n        communication_id: communication.id,\n        customer_id: communication.customer_id,\n        ticket_id: communication.ticket_id || null,\n\n        communication_channel: 'openphone_sms',\n        source: 'openphone',\n\n        external_id: externalId,\n        file_type: mimeType,\n        file_name: fileName,\n        file_url: fileUrl,\n        mime_type: mimeType,\n        size_bytes: sizeBytes,\n\n        storage_bucket: null,\n        storage_path: null,\n\n        raw_attachment: att\n      }\n    });\n  }\n}\n\nreturn output;"
      },
