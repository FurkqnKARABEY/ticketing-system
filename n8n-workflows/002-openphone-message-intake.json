    {
      "parameters": {
        "jsCode": "const drive = $json;\nconst original = $('Extract Message Attachments').item.json;\n\nconst driveFileId = drive.id || drive.fileId || null;\n\nconst driveViewLink =\n  drive.webViewLink ||\n  drive.webContentLink ||\n  (driveFileId ? `https://drive.google.com/file/d/${driveFileId}/view` : original.file_url);\n\nreturn [\n  {\n    json: {\n      communication_id: original.communication_id,\n      customer_id: original.customer_id,\n      ticket_id: original.ticket_id || null,\n\n      communication_channel: original.communication_channel,\n      source: original.source,\n\n      external_id: original.external_id,\n      file_type: original.file_type,\n      file_name: original.file_name,\n      mime_type: original.mime_type,\n      size_bytes: original.size_bytes,\n\n      file_url: driveViewLink,\n      storage_bucket: 'google_drive',\n      storage_path: driveFileId,\n\n      original_file_url: original.file_url\n    }\n  }\n];"
      },
