      "alwaysOutputData": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const response = item.json || {};\n\n  const original =\n    $('Extract Recording Info').item.json ||\n    $('Filter Calls Needing Enrichment').item.json;\n\n  let transcriptText =\n    response.text ||\n    response.transcript ||\n    response.transcriptText ||\n    response.data?.text ||\n    response.data?.transcript ||\n    response.data?.transcriptText ||\n    response.data?.object?.text ||\n    response.data?.object?.transcript ||\n    response.data?.object?.transcriptText ||\n    null;\n\n  const segments =\n    response.segments ||\n    response.data?.segments ||\n    response.data?.object?.segments ||\n    response.transcript?.segments ||\n    response.data?.transcript?.segments ||\n    [];\n\n  if (!transcriptText && Array.isArray(segments) && segments.length) {\n    transcriptText = segments\n      .map(s => {\n        const speaker = s.speaker || s.role || s.author || '';\n        const text = s.text || s.content || s.message || '';\n        return speaker ? `${speaker}: ${text}` : text;\n      })\n      .filter(Boolean)\n      .join('\\n');\n  }\n\n  return {\n    json: {\n      ...original,\n      transcript_text_found: transcriptText,\n      transcript_raw_response: response\n    }\n  };\n});"
      },
