      "name": "Find Calls Needing Enrichment"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.filter(item => {\n  const j = item.json;\n\n  const hasCallId = !!j.openphone_call_id;\n  const isTestCall = String(j.openphone_call_id || '').startsWith('test-call-');\n\n  const missingRecording = !j.recording_url;\n  const missingTranscript = !j.transcript_text && !j.transcript_url;\n  const missingSummary = !j.summary;\n\n  return hasCallId && !isTestCall && (missingRecording || missingTranscript || missingSummary);\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        224
      ],
      "id": "abb7a457-4720-4c16-a3d0-5b3fafdc4d18",
      "name": "Filter Calls Needing Enrichment"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const response = item.json || {};\n  const original = $('Filter Calls Needing Enrichment').item.json;\n\n  const recordingUrl =\n    response.url ||\n    response.recordingUrl ||\n    response.recording_url ||\n    response.data?.url ||\n    response.data?.recordingUrl ||\n    response.data?.recording_url ||\n    response.data?.object?.url ||\n    response.data?.object?.recordingUrl ||\n    response.data?.object?.recording_url ||\n    null;\n\n  return {\n    json: {\n      communication_id: original.id,\n      openphone_call_id: original.openphone_call_id,\n      existing_recording_url: original.recording_url,\n      recording_url_found: recordingUrl,\n      recording_raw_response: response\n    }\n  };\n});"
      },
