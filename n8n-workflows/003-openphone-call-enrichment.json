        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const response = item.json || {};\n  const original = $('Extract Recording Info').item.json;\n\n  const data = response.data || response;\n\n  const voicemailId = data.id || null;\n  const voicemailStatus = data.status || null;\n  const voicemailTranscript = data.transcript || null;\n  const voicemailRecordingUrl =\n    data.recordingUrl ||\n    data.recording_url ||\n    data.url ||\n    null;\n\n  const voicemailDuration = data.duration || null;\n\n  return {\n    json: {\n      communication_id: original.communication_id,\n      customer_id: original.customer_id || null,\n      ticket_id: original.ticket_id || null,\n      openphone_call_id: original.openphone_call_id,\n\n      voicemail_id: voicemailId,\n      voicemail_status: voicemailStatus,\n      voicemail_transcript: voicemailTranscript,\n      voicemail_recording_url: voicemailRecordingUrl,\n      voicemail_duration: voicemailDuration,\n\n      voicemail_raw_response: response\n    }\n  };\n});"
