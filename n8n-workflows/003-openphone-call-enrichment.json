      "parameters": {
        "jsCode": "const drive = $json;\nconst original = $('Extract Recording Info').item.json;\n\nconst driveFileId = drive.id || drive.fileId || null;\n\nconst driveViewLink =\n  drive.webViewLink ||\n  drive.webContentLink ||\n  (driveFileId ? `https://drive.google.com/file/d/${driveFileId}/view` : original.recording_url_found);\n\nreturn [\n  {\n    json: {\n      communication_id: original.communication_id,\n      customer_id: original.customer_id || null,\n      ticket_id: original.ticket_id || null,\n\n      communication_channel: 'openphone_call',\n      source: 'openphone',\n\n      external_id: original.openphone_call_id,\n      file_type: 'audio/mpeg',\n      file_name: `call-recording-${original.openphone_call_id}.mp3`,\n      mime_type: 'audio/mpeg',\n\n      file_url: driveViewLink,\n      storage_bucket: 'google_drive',\n      storage_path: driveFileId,\n\n      original_file_url: original.recording_url_found\n    }\n  }\n];"
