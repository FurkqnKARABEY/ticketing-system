    {
      "parameters": {
        "jsCode": "const fullEmailItem = $input.first();\nconst binaries = fullEmailItem.binary || {};\n\nconst communication = $('Create Email Communication').item.json;\nconst email = $('Parse AI Classification').item.json;\n\nlet ticketId = null;\n\ntry {\n  const ticketItems = $items('Create Ticket');\n  if (ticketItems && ticketItems.length > 0) {\n    ticketId = ticketItems[0].json.id || null;\n  }\n} catch (e) {\n  ticketId = null;\n}\n\nconst attachmentEntries = Object.entries(binaries).filter(([key]) =>\n  key.startsWith('attachment_')\n);\n\nreturn attachmentEntries.map(([binaryKey, file], index) => ({\n  json: {\n    communication_id: communication.id,\n    customer_id: communication.customer_id,\n    ticket_id: ticketId,\n\n    communication_channel: 'email',\n    source: 'gmail',\n\n    email_message_id: email.email_message_id,\n\n    external_id: `${email.email_message_id}-${index}`,\n\n    file_name:\n      file.fileName ||\n      `email-attachment-${index + 1}`,\n\n    mime_type:\n      file.mimeType ||\n      null,\n\n    size_bytes:\n      file.fileSize ||\n      null,\n\n    original_binary_key: binaryKey\n  },\n  binary: {\n    data: file\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
