    {
      "parameters": {
        "jsCode": "const communication = $('Create Email Communication').item.json;\nconst ai = $('Parse AI Classification').item.json;\n\nconst now = new Date();\nconst datePart = now.toISOString().slice(0, 10).replace(/-/g, '');\nconst timePart = now.toISOString().slice(11, 19).replace(/:/g, '');\nconst randomPart = Math.floor(Math.random() * 900 + 100);\n\nconst ticketNumber = `TKT-${datePart}-${timePart}-${randomPart}`;\n\nreturn [\n  {\n    json: {\n      ticket_number: ticketNumber,\n\n      customer_id: communication.customer_id || null,\n      order_id: null,\n\n      title: ai.ai_summary || ai.subject || 'Email support request',\n      description: ai.message_body || '',\n\n      category: ai.ai_category || 'general_support',\n      status: 'new',\n      priority: ai.ai_priority || 'normal',\n      source: 'email',\n\n      last_activity_at: ai.occurred_at || new Date().toISOString(),\n\n      communication_id: communication.id\n    }\n  }\n];"
      },
