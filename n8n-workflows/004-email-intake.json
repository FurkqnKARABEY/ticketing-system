      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        2480,
        80
      ],
      "id": "e545a6ef-6103-4fa1-9c08-186b13f4e3e1",
      "name": "Upload Email Attachment to Drive"
    },
    {
      "parameters": {
        "jsCode": "const drive = $json;\nconst original = $('Extract Email Attachments').item.json;\n\nconst driveFileId = drive.id || drive.fileId || null;\n\nconst driveViewLink =\n  drive.webViewLink ||\n  drive.webContentLink ||\n  (driveFileId\n    ? `https://drive.google.com/file/d/${driveFileId}/view`\n    : null);\n\nfunction sizeToBytes(value) {\n  if (value === null || value === undefined || value === '') return null;\n\n  if (typeof value === 'number') {\n    return Math.round(value);\n  }\n\n  const text = String(value).trim().toLowerCase();\n\n  // Sadece sayıysa direkt döndür\n  if (/^\\d+$/.test(text)) {\n    return Number(text);\n  }\n\n  const match = text.match(/^([\\d.]+)\\s*(b|kb|kib|mb|mib|gb|gib)?$/i);\n\n  if (!match) return null;\n\n  const amount = parseFloat(match[1]);\n  const unit = (match[2] || 'b').toLowerCase();\n\n  const multipliers = {\n    b: 1,\n    kb: 1000,\n    kib: 1024,\n    mb: 1000 * 1000,\n    mib: 1024 * 1024,\n    gb: 1000 * 1000 * 1000,\n    gib: 1024 * 1024 * 1024\n  };\n\n  return Math.round(amount * (multipliers[unit] || 1));\n}\n\nreturn [\n  {\n    json: {\n      communication_id: original.communication_id,\n      customer_id: original.customer_id,\n      ticket_id: original.ticket_id || null,\n\n      communication_channel: original.communication_channel,\n      source: original.source,\n\n      external_id: original.external_id,\n      file_type: original.mime_type,\n      file_name: original.file_name,\n      mime_type: original.mime_type,\n      size_bytes: sizeToBytes(original.size_bytes),\n\n      file_url: driveViewLink,\n      storage_bucket: 'google_drive',\n      storage_path: driveFileId\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2656,
        80
      ],
      "id": "5b577b5a-38ca-49ac-9e73-cbf5dde1c060",
