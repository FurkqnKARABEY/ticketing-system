      "id": "ed80aec3-d346-458e-b280-526c2ee9b021",
      "name": "Gmail Trigger"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfunction clean(value) {\n  return String(value || '').trim();\n}\n\nfunction extractEmail(value) {\n  const text = clean(value);\n  const match = text.match(/<([^>]+)>/);\n\n  if (match) return match[1].toLowerCase();\n\n  const emailMatch = text.match(/[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}/i);\n  return emailMatch ? emailMatch[0].toLowerCase() : text.toLowerCase();\n}\n\nfunction extractName(value) {\n  const text = clean(value);\n\n  if (!text) return null;\n\n  const beforeBracket = text.split('<')[0].trim();\n  return beforeBracket || null;\n}\n\nfunction toIsoDate(value) {\n  if (!value) return new Date().toISOString();\n\n  const numeric = Number(value);\n\n  // Gmail internalDate çoğunlukla millisecond timestamp olarak gelir\n  if (Number.isFinite(numeric)) {\n    const milliseconds =\n      numeric > 1000000000000\n        ? numeric\n        : numeric * 1000;\n\n    const date = new Date(milliseconds);\n\n    if (!isNaN(date.getTime())) {\n      return date.toISOString();\n    }\n  }\n\n  // Normal date string gelirse onu da ISO'ya çevirir\n  const parsedDate = new Date(value);\n\n  if (!isNaN(parsedDate.getTime())) {\n    return parsedDate.toISOString();\n  }\n\n  return new Date().toISOString();\n}\n\nreturn items.map(item => {\n  const j = item.json || {};\n\n  const fromRaw =\n    j.from ||\n    j.From ||\n    j.headers?.from ||\n    j.payload?.headers?.find?.(h => h.name?.toLowerCase() === 'from')?.value ||\n    '';\n\n  const subject =\n    j.subject ||\n    j.Subject ||\n    j.headers?.subject ||\n    j.payload?.headers?.find?.(h => h.name?.toLowerCase() === 'subject')?.value ||\n    '';\n\n  const body =\n    j.textPlain ||\n    j.text ||\n    j.body ||\n    j.snippet ||\n    j.textHtml ||\n    '';\n\n  const messageId =\n    j.id ||\n    j.messageId ||\n    j.threadId ||\n    j.email_message_id ||\n    null;\n\n  const occurredAt = toIsoDate(\n    j.date ||\n    j.internalDate ||\n    j.createdAt\n  );\n\n  return {\n    json: {\n      channel: 'email',\n      direction: 'incoming',\n      author_type: 'customer',\n\n      author_name: extractName(fromRaw),\n      email_address: extractEmail(fromRaw),\n\n      subject: clean(subject),\n      message_body: clean(body),\n      message_type: 'email',\n\n      email_message_id: messageId,\n      external_id: messageId,\n\n      occurred_at: occurredAt,\n      raw_payload: j\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -464,
        80
      ],
      "id": "d5ede2cd-d884-4d3e-9c3c-533ede6fa225",
      "name": "Normalize Email"
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "GPT-4O-MINI"
        },
        "responses": {
          "values": [
            {
              "content": "=You are an email classification assistant for a customer support desk.\n\nAnalyze the email and return ONLY valid JSON. Do not include markdown, explanation, or extra text.\n\nDecide:\n- whether this email is related to a customer, order, product, warranty, return, shipping, service, sales, or support request\n- whether it needs a ticket/case\n- category\n- priority\n- short summary\n\nUse these categories:\ntechnical_support\nwarranty\nreturn_refund\nshipping_delivery\nparts_request\nsales_question\norder_question\ncomplaint\ngeneral_support\nnot_customer_related\n\nUse these priorities:\nlow\nnormal\nhigh\nurgent\n\nRules:\n- Marketing emails, newsletters, spam, vendor promotions, generic notifications are not customer related.\n- Customer complaints, damaged item reports, warranty issues, return/refund requests, delivery problems, technical problems, parts requests need a ticket.\n- Simple questions can be customer related but may not need a ticket unless follow-up is required.\n\nEmail:\nFrom: {{ $json.author_name }} <{{ $json.email_address }}>\nSubject: {{ $json.subject }}\nBody: {{ $json.message_body }}\n\nReturn JSON exactly like this:\n{\n  \"is_customer_related\": true,\n  \"needs_ticket\": false,\n  \"category\": \"general_support\",\n  \"priority\": \"normal\",\n  \"summary\": \"Short summary here\",\n  \"reason\": \"Short reason here\"\n}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
      "position": [
        -304,
        80
      ],
      "id": "175aa871-0596-4d6e-b83f-8ca091c1d144",
      "name": "AI Classify Email"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfunction getText(j) {\n  return (\n    j.text ||\n    j.output_text ||\n    j.output?.[0]?.content?.[0]?.text ||\n    j.output?.content?.[0]?.text ||\n    j.message?.content ||\n    ''\n  );\n}\n\nreturn items.map(item => {\n  const j = item.json || {};\n  let text = getText(j);\n\n  if (typeof text !== 'string') {\n    text = JSON.stringify(text);\n  }\n\n  text = text.trim();\n\n  // Remove markdown fences if AI ever adds them\n  text = text.replace(/^```json/i, '').replace(/^```/i, '').replace(/```$/i, '').trim();\n\n  let parsed;\n\n  try {\n    parsed = JSON.parse(text);\n  } catch (e) {\n    parsed = {\n      is_customer_related: false,\n      needs_ticket: false,\n      category: 'not_customer_related',\n      priority: 'low',\n      summary: 'AI classification parse failed.',\n      reason: text.slice(0, 500)\n    };\n  }\n\n  const email = $('Normalize Email').item.json;\n\n  return {\n    json: {\n      ...email,\n      ai_is_customer_related: !!parsed.is_customer_related,\n      ai_needs_ticket: !!parsed.needs_ticket,\n      ai_category: parsed.category || 'general_support',\n      ai_priority: parsed.priority || 'normal',\n      ai_summary: parsed.summary || '',\n      ai_reason: parsed.reason || '',\n      ai_raw: parsed\n    }\n  };\n});"
      },
