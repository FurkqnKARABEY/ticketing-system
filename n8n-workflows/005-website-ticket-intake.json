    {
      "parameters": {
        "jsCode": "const customer = $json;\nconst form = $('Normalize Website Ticket Request').item.json;\n\nconst now = new Date();\nconst datePart = now.toISOString().slice(0, 10).replace(/-/g, '');\nconst timePart = now.toISOString().slice(11, 19).replace(/:/g, '');\nconst randomPart = Math.floor(Math.random() * 900 + 100);\n\nconst ticketNumber = `TKT-${datePart}-${timePart}-${randomPart}`;\n\nreturn [\n  {\n    json: {\n      ticket_number: ticketNumber,\n\n      customer_id: customer.id || null,\n      order_id: null,\n\n      title: form.subject || 'Website support request',\n      description: form.message_body || '',\n\n      category: form.category || 'general_support',\n      status: 'new',\n      priority: 'normal',\n      source: 'website_form',\n\n      product_model: form.product_model || null,\n      order_number: form.order_number || null,\n\n      last_activity_at: form.occurred_at || new Date().toISOString(),\n\n      form_data: form\n    }\n  }\n];"
      },
