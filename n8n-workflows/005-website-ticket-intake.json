      "id": "32bda0f5-4be8-4df3-a4db-46158f571fcc",
      "name": "Respond Ticket Created"
    },
    {
      "parameters": {
        "jsCode": "const webhookItem = $('Webhook').item;\nconst binaries = webhookItem.binary || {};\n\nconst communication = $('Create Website Communication').item.json;\nconst ticket = $('Create Website Ticket').item.json;\nconst form = $('Normalize Website Ticket Request').item.json;\n\nconst binaryEntries = Object.entries(binaries);\n\nreturn binaryEntries.map(([binaryKey, file], index) => ({\n  json: {\n    communication_id: communication.id,\n    customer_id: communication.customer_id,\n    ticket_id: ticket.id,\n\n    communication_channel: 'website_form',\n    source: 'website_form',\n\n    external_id: `${ticket.ticket_number || ticket.id}-file-${index + 1}`,\n\n    file_name:\n      file.fileName ||\n      `website-attachment-${index + 1}`,\n\n    mime_type:\n      file.mimeType ||\n      null,\n\n    size_bytes:\n      file.fileSize ||\n      null,\n\n    original_binary_key: binaryKey,\n\n    ticket_number: ticket.ticket_number,\n    customer_email: form.email_address\n  },\n  binary: {\n    data: file\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1600,
        160
      ],
      "id": "233bd742-9a31-4274-8eb9-000573af543e",
      "name": "Extract Website Attachments"
    },
    {
      "parameters": {
        "name": "={{ $json.file_name || 'website-attachment' }}",
        "driveId": {
          "__rl": true,
          "mode": "list",
          "value": "My Drive"
        },
        "folderId": {
          "__rl": true,
          "value": "YOUR_GOOGLE_DRIVE_FOLDER_ID_WEBSITE_ATTACHMENTS",
          "mode": "id"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        1760,
        160
      ],
      "id": "4f8eba96-9b08-4008-883a-c86351b267c3",
      "name": "Upload Website Attachment to Drive"
    },
    {
      "parameters": {
        "jsCode": "const drive = $json;\nconst original = $('Extract Website Attachments').item.json;\n\nconst driveFileId = drive.id || drive.fileId || null;\n\nconst driveViewLink =\n  drive.webViewLink ||\n  drive.webContentLink ||\n  (driveFileId\n    ? `https://drive.google.com/file/d/${driveFileId}/view`\n    : null);\n\nfunction sizeToBytes(value) {\n  if (value === null || value === undefined || value === '') return null;\n\n  if (typeof value === 'number') {\n    return Math.round(value);\n  }\n\n  const text = String(value).trim().toLowerCase();\n\n  if (/^\\d+$/.test(text)) {\n    return Number(text);\n  }\n\n  const match = text.match(/^([\\d.]+)\\s*(b|kb|kib|mb|mib|gb|gib)?$/i);\n\n  if (!match) return null;\n\n  const amount = parseFloat(match[1]);\n  const unit = (match[2] || 'b').toLowerCase();\n\n  const multipliers = {\n    b: 1,\n    kb: 1000,\n    kib: 1024,\n    mb: 1000 * 1000,\n    mib: 1024 * 1024,\n    gb: 1000 * 1000 * 1000,\n    gib: 1024 * 1024 * 1024\n  };\n\n  return Math.round(amount * (multipliers[unit] || 1));\n}\n\nreturn [\n  {\n    json: {\n      communication_id: original.communication_id,\n      customer_id: original.customer_id,\n      ticket_id: original.ticket_id,\n\n      communication_channel: original.communication_channel,\n      source: original.source,\n\n      external_id: original.external_id,\n      file_type: original.mime_type,\n      file_name: original.file_name,\n      mime_type: original.mime_type,\n      size_bytes: sizeToBytes(original.size_bytes),\n\n      file_url: driveViewLink,\n      storage_bucket: 'google_drive',\n      storage_path: driveFileId\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
