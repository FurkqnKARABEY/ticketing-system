    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfunction clean(value) {\n  return String(value || '').trim();\n}\n\nfunction normalizePhone(value) {\n  const digits = String(value || '').replace(/\\D/g, '');\n\n  if (!digits) return '';\n\n  if (digits.length === 11 && digits.startsWith('1')) {\n    return digits.slice(1);\n  }\n\n  return digits.slice(-10);\n}\n\nfunction safeEmail(value) {\n  return clean(value).toLowerCase();\n}\n\nreturn items.map(item => {\n  const body = item.json.body || item.json || {};\n\n  const firstName = clean(body.first_name);\n  const lastName = clean(body.last_name);\n  const fullName = clean(`${firstName} ${lastName}`);\n\n  const email = safeEmail(body.email);\n  const phone = clean(body.phone);\n  const phoneNormalized = normalizePhone(phone);\n\n  const subject = clean(body.subject || 'Website support request');\n  const message = clean(body.message);\n  const category = clean(body.category || 'general_support');\n\n  return {\n    json: {\n      source: 'website_form',\n\n      first_name: firstName || null,\n      last_name: lastName || null,\n      full_name: fullName || 'Unknown Customer',\n\n      email_address: email || null,\n      phone_number: phone || null,\n      phone_number_normalized: phoneNormalized || null,\n\n      order_number: clean(body.order_number) || null,\n      product_model: clean(body.product_model) || null,\n\n      subject,\n      message_body: message,\n      category,\n\n      occurred_at: new Date().toISOString(),\n\n      raw_payload: body\n    }\n  };\n});"
      },
